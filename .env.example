# API Key de Gemini / Google AI SDK
# El Vercel AI SDK usa GOOGLE_GENERATIVE_AI_API_KEY por defecto.
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_de_gemini

# Alias opcional por compatibilidad con notas previas del proyecto.
GOOGLE_GENERATION_AI_API_KEY=tu_api_key_de_gemini

# Credenciales de Supabase
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase

# URL pública del sitio (para robots.txt / sitemap.xml). Sin barra final.
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# --- Integración de Strava (solo server-side; NUNCA con prefijo NEXT_PUBLIC_) ---
# App registrada en https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Opcional: si se omite, se deriva de NEXT_PUBLIC_SITE_URL + /api/integrations/strava/callback
STRAVA_REDIRECT_URI=https://tu-dominio.com/api/integrations/strava/callback
# Clave AES-256-GCM para cifrar tokens en reposo. 32 bytes aleatorios en Base64:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
STRAVA_TOKEN_ENCRYPTION_KEY=
# Secreto para firmar el OAuth state (HMAC). Cadena aleatoria larga.
STRAVA_STATE_SECRET=

# Service role de Supabase. Uso acotado a la integración de Strava (tokens y
# sincronización server-side). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=
