# API Key de Gemini / Google AI SDK
# El Vercel AI SDK usa GOOGLE_GENERATIVE_AI_API_KEY por defecto.
GOOGLE_GENERATIVE_AI_API_KEY=tu_api_key_de_gemini

# Alias opcional por compatibilidad con notas previas del proyecto.
GOOGLE_GENERATION_AI_API_KEY=tu_api_key_de_gemini

# Credenciales de Supabase
NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_de_supabase
